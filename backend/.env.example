# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=https://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017/studygram_dev

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_secret_here_change_in_production_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=https://localhost:5000/api/auth/google/callback

# OAuth - Facebook
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_CALLBACK_URL=https://localhost:5000/api/auth/facebook/callback

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# HTTPS Certificates
HTTPS_KEY_PATH=../certs/server.key
HTTPS_CERT_PATH=../certs/server.crt

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AI_RATE_LIMIT_MAX_REQUESTS=10
